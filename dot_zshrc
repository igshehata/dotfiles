if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

export PATH="/run/current-system/sw/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.cargo/bin:$PATH"

# bun completions
if [[ -s "$HOME/.bun/_bun" ]]; then
  source "$HOME/.bun/_bun"
fi

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# aliases
alias ci="code-insiders"
alias ls="eza -l --no-permissions --icons --git"
alias ll="eza -la --no-permissions --icons --git"
alias la="eza -a --icons --git"
alias lt="eza -T --no-permissions --icons --level=2 --git"
alias llt="eza -lT --no-permissions --icons --level=2 --git"
alias nv="nvim"
alias py="python3"
alias pip="pip3"
alias drs='sudo darwin-rebuild switch --flake ~/nix-config#{{ .chezmoi.hostname }}'
alias purge="git fetch -p"
alias bathelp='bat --plain --language=help'
help() {
    "$@" --help 2>&1 | bathelp
}

# fnm
FNM_PATH="$HOME/Library/Application Support/fnm"
if command -v fnm >/dev/null 2>&1 && [[ -d "$FNM_PATH" ]]; then
  export PATH="$FNM_PATH:$PATH"
  eval "$(fnm env)"
fi

# Initialize atuin (history sync)
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

if command -v carapace >/dev/null 2>&1; then
  source <(carapace _carapace zsh)
fi

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi
